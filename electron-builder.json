{
  "appId": "com.webloganalyzer.app",
  "productName": "WebLogAnalyzer",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "!node_modules"
  ],
  "win": {
    "target": [
      { "target": "zip", "arch": ["x64"] }
    ],
    "icon": "build/icon.ico",
    "artifactName": "WebLogAnalyzer-${version}-win-x64.zip"
  }
}
