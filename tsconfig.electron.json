{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "outDir": "./dist-electron",
    "rootDir": "./electron",
    "noEmit": false
  },
  "include": ["electron/**/*"]
}
